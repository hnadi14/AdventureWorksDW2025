-- فروش های غیر عادی
-- مبلغ فروش منهای میانگین فروش ها بزرگتر از 3 برابر انحراف معیار
WITH Stats AS
(
SELECT AVG(SalesAmount) AS AvgSales, STDEV(SalesAmount) AS StdSales
    FROM FactInternetSales
)
SELECT f.*
FROM FactInternetSales f
        CROSS JOIN Stats s
WHERE ABS(f.SalesAmount - s.AvgSales) > (3 * s.StdSales);
