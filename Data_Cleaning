--- فروش منفی
-- تعداد منفی
-- هزینه منفی
-- سود منفی
SELECT *
FROM FactInternetSales
WHERE SalesAmount < 0 OR OrderQuantity < 0 Or TotalProductCost < 0 
        OR SalesAmount < TotalProductCost;
