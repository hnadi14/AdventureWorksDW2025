--    بررسی تعداد null ها
SELECT
    COUNT(*) AS TotalRows,
    SUM(CASE WHEN ProductKey IS NULL THEN 1 ELSE 0 END) AS NullProductKey,
    SUM(CASE WHEN CustomerKey IS NULL THEN 1 ELSE 0 END) AS NullCustomerKey,
    SUM(CASE WHEN OrderDateKey IS NULL THEN 1 ELSE 0 END) AS NullOrderDateKey,
    SUM(CASE WHEN SalesAmount IS NULL THEN 1 ELSE 0 END) AS NullSalesAmount,
    SUM(CASE WHEN OrderQuantity IS NULL THEN 1 ELSE 0 END) AS NullOrderQuantity
FROM FactInternetSales;
----------------------------
-- بررسی سفارش های تکراری
SELECT SalesOrderNumber, SalesOrderLineNumber,
    COUNT(*) AS DuplicateCount
FROM FactInternetSales
GROUP BY SalesOrderNumber, SalesOrderLineNumber
HAVING COUNT(*) > 1;
GO
----------------------------------------------------------
-- بررسی مشتریان تکراری
SELECT FirstName, LastName, EmailAddress,
       COUNT(*) AS DuplicateCount
FROM DimCustomer
GROUP BY FirstName, LastName, EmailAddress
HAVING COUNT(*) > 1;
----------------------------------------
-- بررسی تاریخ سفارشات که باید معتبر باشند و در جدول تاریخ ها باشند
SELECT *
FROM FactInternetSales f
    LEFT JOIN DimDate d
        ON f.OrderDateKey = d.DateKey
WHERE d.DateKey IS NULL;
------------------------------------------
-- بررسی تاریخ ارسال قبل از تاریخ سفارش
SELECT *
FROM FactInternetSales
WHERE ShipDateKey < OrderDateKey;
