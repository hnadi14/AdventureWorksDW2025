-- مشتری نامعتبر
SELECT *
FROM FactInternetSales f
    LEFT JOIN DimCustomer c
        ON f.CustomerKey = c.CustomerKey
WHERE c.CustomerKey IS NULL;
--------------------
-- کالای نامعتبر
SELECT *
FROM FactInternetSales f
    LEFT JOIN DimProduct p
        ON f.ProductKey = p.ProductKey
WHERE p.ProductKey IS NULL;
