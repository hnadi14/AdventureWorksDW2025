CREATE OR ALTER VIEW dbo.vw_MostProfitableProducts
AS
-- کالاهای سود آور
-- محاسبه کل فروش
-- کل هزینه
-- سود 
-- حاشیه سود
-- به ازای هر کالا
SELECT p.ProductKey, p.EnglishProductName,
    SUM(f.SalesAmount) AS Revenue,
    SUM(f.TotalProductCost) AS Cost,
    SUM(f.SalesAmount) - SUM(f.TotalProductCost) AS Profit,
    ROUND ((SUM(f.SalesAmount) - SUM(f.TotalProductCost)) * 100.0 / NULLIF ( SUM(f.SalesAmount), 0),2)
        AS ProfitMarginPercent
FROM FactInternetSales f
    INNER JOIN DimProduct p
        ON f.ProductKey = p.ProductKey
GROUP BY p.ProductKey, p.EnglishProductName;
GO

