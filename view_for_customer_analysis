CREATE OR ALTER VIEW dbo.vw_RFMScore
AS
-- RFM
-- تاریخ اخرین خرید
-- تعداد خرید
-- مقدار خرید هر مشتری
WITH CustomerRFM AS
(
    SELECT c.CustomerKey,
        MAX(d.FullDateAlternateKey) AS LastPurchaseDate,
        COUNT(DISTINCT f.SalesOrderNumber) AS Frequency,
        SUM(f.SalesAmount) AS Monetary
    FROM FactInternetSales f
        INNER JOIN DimCustomer c
            ON f.CustomerKey = c.CustomerKey
        INNER JOIN DimDate d
            ON f.OrderDateKey = d.DateKey
    GROUP BY c.CustomerKey
),
-- دسته بندی مشتری ها در 5 بخش مجزا
-- با توجه به اخرین خرید، تعداد خرید و مقدار خرید کل
Scored AS
(
    SELECT *,
        NTILE(5) OVER (ORDER BY DATEDIFF (DAY, LastPurchaseDate, GETDATE()) ASC ) AS R_Score,
        NTILE(5) OVER (ORDER BY Frequency DESC ) AS F_Score,
        NTILE(5) OVER (ORDER BY Monetary DESC ) AS M_Score
    FROM CustomerRFM
)
SELECT *,
    CONCAT (R_Score, F_Score, M_Score ) AS RFMScore
FROM Scored;
GO
