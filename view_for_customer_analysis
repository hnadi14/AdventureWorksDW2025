CREATE OR ALTER VIEW dbo.vw_CustomerSegmentation
AS
-- دسته بندی مشتریان بر اساس مقدار خرید
WITH CustomerSales AS
(
    SELECT
        c.CustomerKey, c.FirstName + ' ' + c.LastName AS CustomerName,
        SUM(f.SalesAmount) AS TotalRevenue,
        COUNT(DISTINCT f.SalesOrderNumber) AS TotalOrders
    FROM FactInternetSales f
        INNER JOIN DimCustomer c
            ON f.CustomerKey = c.CustomerKey
    GROUP BY c.CustomerKey, c.FirstName, c.LastName
)
-- برچسب بر اساس مقدار خرید
SELECT *,
    CASE
        WHEN TotalRevenue >= 10000
            THEN 'Platinum'
        WHEN TotalRevenue >= 5000
            THEN 'Gold'
        WHEN TotalRevenue >= 2000
            THEN 'Silver'
        ELSE 'Bronze'
    END AS CustomerSegment
FROM CustomerSales;
GO
