CREATE OR ALTER VIEW dbo.vw_CustomerLifetimeValue
AS
-- Customer Lifetime Value
-- محاسبه مقدار خرید هر مشتری
-- محاسبه تعداد خرید های مشتری
-- تاریخ اولین خرید مشتری
-- تاریخ اخرین خرید هر مشتری
-- 
WITH CustomerMetrics AS
(
    SELECT c.CustomerKey, c.FirstName + ' ' + c.LastName AS CustomerName,
        SUM(f.SalesAmount) AS TotalRevenue,
        COUNT(DISTINCT f.SalesOrderNumber) AS TotalOrders,
        MIN(d.FullDateAlternateKey) AS FirstPurchaseDate,
        MAX(d.FullDateAlternateKey) AS LastPurchaseDate
    FROM FactInternetSales f
        INNER JOIN DimCustomer c
            ON f.CustomerKey = c.CustomerKey
        INNER JOIN DimDate d
            ON f.OrderDateKey = d.DateKey
    GROUP BY c.CustomerKey, c.FirstName, c.LastName
)
-- محاسبه میانگین خرید هر مشتری
-- محاسبه تعداد روز مشتری از خرید اول تا خرید اخر
SELECT *,
        TotalRevenue / NULLIF(TotalOrders,0) AS AverageOrderValue,
        DATEDIFF( DAY, FirstPurchaseDate, LastPurchaseDate ) AS CustomerLifetimeDays
FROM CustomerMetrics;
GO
