CREATE OR ALTER VIEW dbo.vw_ProductMarketShare
AS
-- سهم هر محصول از فروش کل
-- محاسبه مقدار فروش هر محصول
WITH ProductSales AS
(
    SELECT p.EnglishProductName, SUM(f.SalesAmount) AS ProductSales
    FROM FactInternetSales f
        INNER JOIN DimProduct p
            ON f.ProductKey = p.ProductKey
    GROUP BY p.EnglishProductName
)
-- محاسبه درصد فروش هر محصول
SELECT
    EnglishProductName, ProductSales,
    ROUND (ProductSales * 100 / SUM(ProductSales) OVER(), 2 ) AS MarketSharePercent
FROM ProductSales;
GO
