CREATE OR ALTER VIEW dbo.vw_PromotionEffectiveness
AS
-- اثر بخشی کمپین های تبلیغاتی
SELECT p.EnglishPromotionName,
        SUM(f.SalesAmount) AS TotalSales
FROM FactInternetSales f
    INNER JOIN DimPromotion p
        ON f.PromotionKey = p.PromotionKey
GROUP BY p.EnglishPromotionName;
GO
