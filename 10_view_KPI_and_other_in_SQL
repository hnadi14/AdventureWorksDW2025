CREATE OR ALTER VIEW dbo.vw_Pareto80Products
AS
-- محصولاتی که 80 درصد فروش را داشته اند
-- فروش هر محصول
WITH ProductSales AS
(
    SELECT p.EnglishProductName, SUM(f.SalesAmount) AS SalesAmount
    FROM dbo.FactInternetSales f
        INNER JOIN dbo.DimProduct p
            ON p.ProductKey = f.ProductKey
    GROUP BY p.EnglishProductName
),
-- درصد فروش تجمعی
Pareto AS
(
SELECT *,
        SUM(SalesAmount) OVER ( ORDER BY SalesAmount DESC ROWS UNBOUNDED PRECEDING )
        * 100.0 / SUM(SalesAmount) OVER() AS RunningPercent
    FROM ProductSales
)
-- نمایش محصولات با شرط درصد فروش تجمعی 80 درصد و اخرین محصولی که از 80 درصد گذشته است
SELECT *
FROM
(
    SELECT *, LAG (RunningPercent, 1, 0) OVER(ORDER BY SalesAmount DESC) AS PrevPercent
    FROM Pareto
) x
WHERE PrevPercent < 80;
GO
