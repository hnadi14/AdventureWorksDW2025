CREATE OR ALTER VIEW dbo.vw_RevenueGrowthRate
AS
-------------------------------------------------------
-- نرخ رشد سالانه فروش
WITH SalesByYear AS
(
    -- جمع فروش هر سال
    SELECT
        d.CalendarYear, SUM(f.SalesAmount) AS TotalSales
    FROM FactInternetSales f
        INNER JOIN DimDate d
            ON f.OrderDateKey = d.DateKey
    GROUP BY d.CalendarYear
)
-- نرخ رشد نسبت به سال قبل
SELECT
    CalendarYear, TotalSales,
    LAG(TotalSales) OVER(ORDER BY CalendarYear) AS PreviousYear,

    ROUND(
        (TotalSales - LAG(TotalSales) OVER(ORDER BY CalendarYear)) * 100.0
          /NULLIF (LAG(TotalSales) OVER(ORDER BY CalendarYear),0)
    ,2) AS GrowthPercent
FROM SalesByYear;
GO
