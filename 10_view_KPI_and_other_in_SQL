CREATE OR ALTER VIEW dbo.vw_MonthlyRevenueTrend
AS
-------------
-- فروش ماهیانه و میانگین متحرک
-- محاسبه فروش هر ماه
WITH SalesAmount AS
(
    SELECT d.CalendarYear, d.MonthNumberOfYear,
        SUM(f.SalesAmount) AS TotalSales
    FROM FactInternetSales f
    INNER JOIN DimDate d
        ON f.OrderDateKey = d.DateKey
    GROUP BY d.CalendarYear, d.MonthNumberOfYear
)
-- محاسبه فروش میانگین 3 ماهه
SELECT *,
    AVG(TotalSales) OVER (ORDER BY CalendarYear, MonthNumberOfYear ROWS BETWEEN 2 PRECEDING AND CURRENT ROW
    ) AS MovingAverage_3_Month
FROM SalesAmount;
GO

