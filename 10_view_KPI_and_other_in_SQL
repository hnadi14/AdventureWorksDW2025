CREATE OR ALTER VIEW dbo.vw_ExecutiveKPIs
AS
-- محاسبه فروش کل
-- محاسبه هزینه کل
-- محاسبه تعداد سفارش ها
-- محاسبه میانگین فروش در هر سفارش
-- محاسبه میانگین سود
SELECT
    SUM(SalesAmount) AS Revenue,
    SUM(TotalProductCost) AS Cost,
    SUM(SalesAmount) - SUM(TotalProductCost) AS Profit,
    (SUM(SalesAmount) - SUM(TotalProductCost)) / COUNT(DISTINCT SalesOrderNumber) AverageProfit,
    COUNT(DISTINCT SalesOrderNumber) AS Orders,
    SUM(SalesAmount) / COUNT(DISTINCT SalesOrderNumber) AS AverageOrderValue
FROM FactInternetSales;
GO
