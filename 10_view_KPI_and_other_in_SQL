CREATE OR ALTER VIEW dbo.vw_TopProductsRevenue
AS

-- 10 محصول پرفروش
-- درصد فروش هر محصول
--- یافتن 10 محصول پر فروش
WITH ProductSales AS
(
    SELECT TOP (10) p.EnglishProductName, SUM(f.SalesAmount) AS TotalSales
    FROM FactInternetSales f
            INNER JOIN DimProduct p
                ON f.ProductKey = p.ProductKey
    GROUP BY p.EnglishProductName
    ORDER BY TotalSales DESC
),
-- محاسبه فروش کل
TotalAllSales AS
(
    SELECT SUM(SalesAmount) AS GrandTotal
    FROM FactInternetSales
)
-- محاسبه درصد فروش هر محصول و درصد فروش تجمعی
SELECT ps.EnglishProductName, ps.TotalSales,
    (ps.TotalSales / tas.GrandTotal) * 100 AS SalesPercentage,
    SUM(ps.TotalSales) OVER(ORDER BY ps.TotalSales DESC)
    / tas.GrandTotal * 100 AS CumulativePercentage
FROM ProductSales ps
CROSS JOIN TotalAllSales tas;
GO
